{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html",  "use": "@vercel/static" }
  ],
  "functions": {
    "api/generate-carousel-ia.js":     { "maxDuration": 60 },
    "api/generate-carousel.js":        { "maxDuration": 60 },
    "api/generate-styled-slide.js":    { "maxDuration": 60 },
    "api/save-carousel.js":            { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/generate-carousel",     "dest": "/api/generate-carousel.js" },
    { "src": "/api/generate-carousel-ia",  "dest": "/api/generate-carousel-ia.js" },
    { "src": "/api/generate-slide-image",  "dest": "/api/generate-slide-image.js" },
    { "src": "/api/analyze-style",         "dest": "/api/analyze-style.js" },
    { "src": "/api/generate-styled-slide", "dest": "/api/generate-styled-slide.js" },
    { "src": "/api/save-carousel",         "dest": "/api/save-carousel.js" },
    { "src": "/api/upload-slide",          "dest": "/api/upload-slide.js" },
    { "src": "/api/rate-carousel",         "dest": "/api/rate-carousel.js" },
    { "src": "/api/confirm-carousel",      "dest": "/api/confirm-carousel.js" },
    { "src": "/api/list-carousels",        "dest": "/api/list-carousels.js" },
    { "src": "/api/get-carousel",          "dest": "/api/get-carousel.js" },
    { "src": "/",                          "dest": "/index.html" }
  ]
}
